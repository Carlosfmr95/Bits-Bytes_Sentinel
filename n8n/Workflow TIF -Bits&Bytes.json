      "id": "c00b3772-c758-4a94-bac0-428de76c66c2",
      "name": "Nmap - Escanear puertos y servicios2",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        272,
        448
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst ahora = new Date().toISOString();\nconst rows = [];\n\nfunction clasificar(servicio, puerto) {\n  const alto  = ['ftp','telnet','rlogin','rsh','vnc','ms-wbt-server'];\n  const medio = ['http','smtp','pop3','imap','snmp','netbios-ssn','mysql','postgresql'];\n  if (alto.includes(servicio))  return 'HIGH';\n  if (medio.includes(servicio)) return 'MEDIUM';\n  if (puerto < 1024)            return 'MEDIUM';\n  return 'LOW';\n}\n\nfor (const item of items) {\n  const scan  = item.json;\n  const hosts = scan.hosts || [];\n  for (const host of hosts) {\n    for (const port of (host.ports || [])) {\n      if (!port.open) continue;\n      rows.push({\n        scan_fecha:      ahora,\n        host_ip:         host.ip,\n        hostname:        host.hostname || 'N/A',\n        puerto:          port.port,\n        protocolo:       port.protocol,\n        servicio:        port.service || 'unknown',\n        version:         port.version || 'N/A',\n        severidad_label: clasificar(port.service, port.port)\n      });\n    }\n  }\n}\n\nif (rows.length === 0) {\n  return [{ json: { warning: 'Sin puertos abiertos encontrados' } }];\n}\n\nreturn rows.map(r => ({ json: r }));"
      },
      "id": "718d13a2-347b-46b8-b418-3ceeeb915539",
      "name": "Parsear y Clasificar Resultados2",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        496,
        448
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nif (items.length === 1 && items[0].json.warning) {\n  return [{ json: { warning: items[0].json.warning, hosts: [] } }];\n}\n\nconst hostsMap = {};\nfor (const item of items) {\n  const r = item.json;\n  if (!hostsMap[r.host_ip]) {\n    hostsMap[r.host_ip] = {\n      host_ip:    r.host_ip,\n      hostname:   r.hostname || 'N/A',\n      scan_fecha: r.scan_fecha,\n      puertos:    [],\n      high: 0, medium: 0, low: 0\n    };\n  }\n  hostsMap[r.host_ip].puertos.push({\n    puerto:    r.puerto,\n    protocolo: r.protocolo,\n    servicio:  r.servicio,\n    version:   r.version,\n    severidad: r.severidad_label\n  });\n  if      (r.severidad_label === 'HIGH')   hostsMap[r.host_ip].high++;\n  else if (r.severidad_label === 'MEDIUM') hostsMap[r.host_ip].medium++;\n  else                                     hostsMap[r.host_ip].low++;\n}\n\nreturn Object.values(hostsMap).map(h => ({ json: h }));"
      },
      "id": "17cb69ae-5ce4-4e63-9030-b575c99f4b17",
      "name": "Agregar Resultados Nmap1",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
