      "parameters": {
        "jsCode": "const data = $('📋 Generar Reporte Final2').first().json;\nconst ahora = new Date().toLocaleString('sv-SE', { timeZone: 'America/Argentina/Buenos_Aires' }).replace(' ','T');\n\nreturn [{\n  json: {\n    scan_id:        data.scan_id,\n    fecha:          ahora,\n    total_hosts:    (data.nmap_rows || []).length,\n    nmap_high:      data.resumen.nmap.high,\n    nmap_medium:    data.resumen.nmap.medium,\n    nmap_low:       data.resumen.nmap.low,\n    openvas_high:   data.resumen.openvas.high,\n    openvas_medium: data.resumen.openvas.medium,\n    openvas_low:    data.resumen.openvas.low\n  }\n}];"
      },
