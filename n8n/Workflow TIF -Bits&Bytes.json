      "id": "5df33f19-ae69-443c-86b2-0d1d49e42d3b",
      "name": "OpenVAS - Obtener Reporte1",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2064,
        448
      ]
    },
    {
      "parameters": {
        "jsCode": "const openvasItems = $input.all();\nconst nmapItems = $('Agregar Resultados Nmap1').all();\nconst scan_id = $('Generar Scan ID').first().json.scan_id;\n\nconst ahora = new Date().toLocaleString('es-AR', {\n  timeZone: 'America/Argentina/Buenos_Aires',\n  dateStyle: 'full',\n  timeStyle: 'short'\n});\n\nlet nmapTotalHigh = 0, nmapTotalMedium = 0, nmapTotalLow = 0;\nlet secNmap = '';\n\nfor (const h of nmapItems.map(i => i.json)) {\n  nmapTotalHigh   += h.high   || 0;\n  nmapTotalMedium += h.medium || 0;\n  nmapTotalLow    += h.low    || 0;\n  secNmap += `### ${h.host_ip} (${h.hostname})\\n`;\n  secNmap += `| Puerto | Servicio | Versión | Riesgo |\\n|--------|----------|---------|--------|\\n`;\n  for (const p of (h.puertos || [])) {\n    const emoji = p.severidad === 'HIGH' ? '🔴' : p.severidad === 'MEDIUM' ? '🟡' : '🟢';\n    secNmap += `| ${p.puerto}/${p.protocolo} | ${p.servicio} | ${p.version} | ${emoji} ${p.severidad} |\\n`;\n  }\n  secNmap += '\\n';\n}\n\nconst openvasResultados = [];\nfor (const item of openvasItems) {\n  if (item.json.resultados) openvasResultados.push(...item.json.resultados);\n}\n\nlet ovasTotalHigh = 0, ovasTotalMedium = 0, ovasTotalLow = 0;\nlet secOvas = '';\n\nif (openvasResultados.length > 0) {\n  for (const v of openvasResultados) {\n    if      (v.severidad_label === 'HIGH')   ovasTotalHigh++;\n    else if (v.severidad_label === 'MEDIUM') ovasTotalMedium++;\n    else if (v.severidad_label === 'LOW')    ovasTotalLow++;\n  }\n  secOvas += `**Total:** ${openvasResultados.length}\\n\\n`;\n  secOvas += `| Severidad | Cantidad |\\n|-----------|----------|\\n`;\n  secOvas += `| 🔴 Alta | ${ovasTotalHigh} |\\n| 🟡 Media | ${ovasTotalMedium} |\\n| 🟢 Baja | ${ovasTotalLow} |\\n\\n`;\n  const top = openvasResultados.slice(0, 10);\n  secOvas += `#### Top vulnerabilidades\\n\\n| CVEs | Nombre | Host:Puerto | CVSS |\\n|------|--------|-------------|------|\\n`;\n  for (const v of top) {\n    const cves = (v.cves||[]).length > 0 ? v.cves.join(' ') : 'N/A';\n    const nombre = v.nombre.length > 50 ? v.nombre.slice(0,47)+'...' : v.nombre;\n    secOvas += `| ${cves} | ${nombre} | ${v.host}:${v.puerto} | ${v.severidad_cvss} |\\n`;\n  }\n} else {\n  secOvas = '*Sin resultados de OpenVAS disponibles.*\\n';\n}\n\nconst reporte = `# 🔒 Reporte de Escaneo de Vulnerabilidades\n\n**Grupo:** Bits & Bytes — Marín, Agustín · Muñoz, Carlos · Raia, Sofía  \n**Institución:** UTN FRM – Tecnicatura Universitaria en Programación  \n**Fecha:** ${ahora}  \n**Scan ID:** ${scan_id}  \n\n---\n\n## 📊 Resumen Ejecutivo\n\n| Herramienta | 🔴 Alto | 🟡 Medio | 🟢 Bajo |\n|-------------|---------|----------|--------|\n| Nmap | ${nmapTotalHigh} | ${nmapTotalMedium} | ${nmapTotalLow} |\n| OpenVAS | ${ovasTotalHigh} | ${ovasTotalMedium} | ${ovasTotalLow} |\n\n---\n\n## 🗺️ Resultados Nmap\n\n${secNmap || '*Sin resultados.*'}\n\n---\n\n## 🔍 Resultados OpenVAS\n\n${secOvas}\n\n---\n\n## 📋 Recomendaciones\n\n1. **Priorizar** remediación de vulnerabilidades con CVSS ≥ 7.0\n2. **Deshabilitar** servicios innecesarios (telnet, ftp, rlogin)\n3. **Aplicar parches** en todos los sistemas identificados\n4. **Revisar** configuraciones de servicios expuestos\n5. **Repetir** el escaneo después de aplicar correcciones\n\n---\n\n*Reporte generado automáticamente — Sistema de Escaneo Automatizado de Vulnerabilidades*\n`;\n\nreturn [{\n  json: {\n    reporte_markdown: reporte,\n    fecha: ahora,\n    scan_id,\n    nmap_rows: nmapItems.map(i => i.json),\n    openvas_resultados: openvasResultados,\n    resumen: {\n      nmap:    { high: nmapTotalHigh,  medium: nmapTotalMedium,  low: nmapTotalLow },\n      openvas: { high: ovasTotalHigh, medium: ovasTotalMedium, low: ovasTotalLow }\n    }\n  }\n}];"
      },
      "id": "e931cc5b-98ab-4e91-85da-5bc748bbc7cd",
      "name": "📋 Generar Reporte Final2",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2288,
