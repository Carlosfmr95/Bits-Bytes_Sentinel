      "id": "4d9b88f6-7fbe-43ff-b7c1-34f23dd8df15",
      "name": "Nmap - Descubrir hosts activos2",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -176,
        352
      ]
    },
    {
      "parameters": {
        "jsCode": "const result = $input.first().json;\nconst hostsUp = result.hosts_up || [];\n\nconst targets = hostsUp.filter(ip =>\n  ip !== '192.168.100.5' && ip !== '192.168.100.1'\n);\n\nif (targets.length === 0) {\n  return [{ json: { error: 'Sin hosts objetivo encontrados', hosts_encontrados: hostsUp } }];\n}\n\nreturn targets.map(ip => ({ json: { target_ip: ip } }));"
      },
      "id": "5d940516-e8bf-4e68-8bc6-2e8880259b37",
      "name": "Preparar lista de targets2",
      "type": "n8n-nodes-base.code",
