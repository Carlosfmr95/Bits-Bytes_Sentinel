      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items\n  .filter(item => item.json.task_id)\n  .map(item => ({\n    json: {\n      task_id:   item.json.task_id,\n      report_id: item.json.report_id,\n      target_ip: item.json.target_ip,\n      scan_name: item.json.scan_name\n    }\n  }));"
      },
