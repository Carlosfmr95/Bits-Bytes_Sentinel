      "id": "3b8720e9-ab20-41fd-91e3-0b79c2d55d6b",
      "name": "▶ Ejecutar Manual",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        -624,
        160
      ]
    },
    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst pad = n => String(n).padStart(2, '0');\n\n// Intentar leer el scan_id que mandó el dashboard via Webhook.\n// Si el workflow fue disparado por Manual Trigger o Schedule, este bloque\n// falla silenciosamente y se genera un ID propio.\nlet scan_id = null;\nlet webhook_target = null;\nlet webhook_scan_type = null;\n\ntry {\n  const wb   = $('Webhook - Dashboard').first().json;\n  const data = wb.body || wb;\n\n  if (data && data.scan_id) {\n    scan_id           = data.scan_id;\n    webhook_target    = data.target    || null;\n    webhook_scan_type = data.scan_type || null;\n  }\n} catch (e) {\n  // No viene del Webhook — es Manual o Schedule, sin problema\n}\n\n// Si no vino del Webhook, generar el ID propio (formato original)\nif (!scan_id) {\n  scan_id = `SCAN-${now.getFullYear()}${pad(now.getMonth()+1)}${pad(now.getDate())}-${pad(now.getHours())}${pad(now.getMinutes())}${pad(now.getSeconds())}`;\n}\n\nreturn [{ json: { scan_id, webhook_target, webhook_scan_type } }];"
      },
      "id": "f3ee05c2-6f6f-4d4a-a5e0-c4de2503922b",
      "name": "Generar Scan ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -400,
        352
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst ahora = new Date().toLocaleString('sv-SE', { timeZone: 'America/Argentina/Buenos_Aires' }).replace(' ','T');\nconst rows = [];\n\nfor (const h of (data.nmap_rows || [])) {\n  if (!h.host_ip) continue;\n  for (const p of (h.puertos || [])) {\n    rows.push({\n      scan_id:         data.scan_id,\n      fecha:           ahora,\n      host_ip:         h.host_ip,\n      herramienta:     'nmap',\n      severidad_label: p.severidad,\n      puerto:          String(p.puerto),\n      servicio:        p.servicio || null,\n      version:         p.version  || null,\n      nombre_vuln:     null,\n      cves:            null,\n      severidad_cvss:  null\n    });\n  }\n}\n\nfor (const v of (data.openvas_resultados || [])) {\n  rows.push({\n    scan_id:         data.scan_id,\n    fecha:           ahora,\n    host_ip:         v.host,\n    herramienta:     'openvas',\n    severidad_label: v.severidad_label,\n    puerto:          v.puerto  || null,\n    servicio:        null,\n    version:         null,\n    nombre_vuln:     v.nombre  || null,\n    cves:            (v.cves || []).join(',') || null,\n    severidad_cvss:  v.severidad_cvss || null\n  });\n}\n\nif (rows.length === 0) return [{ json: { __skip: true } }];\n\nreturn rows.map(r => ({ json: r }));"
      },
      "id": "d311e1d9-e47b-4321-8445-fc2ba64871a6",
      "name": "Preparar filas para DB",
