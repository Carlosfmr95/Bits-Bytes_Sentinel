      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=http://nmap-api:5000/scan/{{ $('Generar Scan ID').first().json.webhook_scan_type === 'full' ? 'full' : 'quick' }}",
        "sendBody": true,
